{
  "family": "task-def-bia-dev",
  "executionRoleArn": "arn:aws:iam::843976228713:role/ecsTaskExecutionRole",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "cpu": "512",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "bia",
      "image": "843976228713.dkr.ecr.us-east-1.amazonaws.com/bia:latest",
      "cpu": 512,
      "memory": 512,
      "memoryReservation": 300,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 0,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_PWD",
          "value": "uqu4C6VhK4LOpDv3m5e7"
        },
        {
          "name": "DB_HOST",
          "value": "bia.ce3suii0qq9u.us-east-1.rds.amazonaws.com"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_USER",
          "value": "postgres"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/task-def-bia-dev",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
